generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BOSS
  GENERAL_MANAGER
  FINANCIAL_DEPARTMENT
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  PROJECT_MANAGER
  TEAM_LEADER
  TECHNICIAN
  WAREHOUSE_MANAGER
  FLEET_MANAGER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_APPROVED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum Client {
  MAROC_TELECOM
  INWI
  ERICSSON
  NOKIA
  OTHER
}

enum WorkType {
  INSTALLATION
  MAINTENANCE
  UPGRADE
  DISMANTLING
  FIBER
  POWER
  CIVIL
  AUDIT
}

enum Technology {
  TWO_G
  THREE_G
  FOUR_G
  FIVE_G
  MICROWAVE
  FIBER
  POWER
  HYBRID
}

enum AllowanceRate {
  MAD_152
  MAD_160
  MAD_175
}

enum PaymentMethod {
  CASH
  BANK
  CARD
  ADVANCE
}

enum MovementType {
  INCOMING
  OUTGOING
}

enum TaxType {
  TVA
  CNSS
  IR
  IS
}

enum LocationType {
  MANUAL
  GOOGLE_MAPS
  GPS
}

enum ProfitStatus {
  PROFITABLE
  RISKY
  LOSS
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role
  active             Boolean             @default(true)
  employee           Employee?
  invitesCreated     Invite[]            @relation("InviteCreator")
  auditLogs          AuditLog[]
  approvals          Approval[]
  locations          LocationUpdate[]
  projectAssignments ProjectAssignment[]
  bossRoomLogs       BossRoomAccessLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Invite {
  id          String                    @id @default(cuid())
  tokenHash   String                    @unique
  email       String
  role        Role
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdById String
  createdBy   User                      @relation("InviteCreator", fields: [createdById], references: [id])
  usageLogs   InviteUsageLog[]
  projects    InviteProjectAssignment[]
  createdAt   DateTime                  @default(now())
}

model InviteProjectAssignment {
  id        String  @id @default(cuid())
  inviteId  String
  projectId String
  invite    Invite  @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([inviteId, projectId])
}

model InviteUsageLog {
  id        String   @id @default(cuid())
  inviteId  String
  invite    Invite   @relation(fields: [inviteId], references: [id])
  email     String?
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())
}

model Employee {
  id              String              @id @default(cuid())
  userId          String?             @unique
  user            User?               @relation(fields: [userId], references: [id])
  fullName        String
  phone           String?
  role            Role
  baseSalary      Decimal             @default(0) @db.Decimal(12, 2)
  allowanceRate   AllowanceRate       @default(MAD_160)
  active          Boolean             @default(true)
  teamMemberships TeamMember[]
  missions        MissionTechnician[]
  vehicle         Vehicle?            @relation("VehicleDriver")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Team {
  id        String       @id @default(cuid())
  name      String
  leaderId  String?
  members   TeamMember[]
  missions  Mission[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  team       Team     @relation(fields: [teamId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([teamId, employeeId])
}

model Project {
  id                String                    @id @default(cuid())
  name              String
  client            Client
  workType          WorkType
  technology        Technology
  region            String
  siteId            String
  startDate         DateTime
  endDate           DateTime?
  status            ProjectStatus             @default(PLANNED)
  contractValue     Decimal                   @db.Decimal(14, 2)
  allocatedBudget   Decimal                   @db.Decimal(14, 2)
  committedBudget   Decimal                   @default(0) @db.Decimal(14, 2)
  actualCost        Decimal                   @default(0) @db.Decimal(14, 2)
  priority          Int                       @default(2)
  complexity        Int                       @default(2)
  missions          Mission[]
  purchases         Purchase[]
  expenses          Expense[]
  advances          AdvanceRequest[]
  stockMoves        StockMovement[]
  vehicles          Vehicle[]
  profitScenarios   ProfitScenario[]
  assignments       ProjectAssignment[]
  inviteAssignments InviteProjectAssignment[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Mission {
  id          String                @id @default(cuid())
  projectId   String
  teamId      String
  vehicleId   String?
  title       String
  location    String
  startDate   DateTime
  endDate     DateTime?
  days        Int
  teamLocked  Boolean               @default(false)
  status      String                @default("PLANNED")
  project     Project               @relation(fields: [projectId], references: [id])
  team        Team                  @relation(fields: [teamId], references: [id])
  vehicle     Vehicle?              @relation(fields: [vehicleId], references: [id])
  technicians MissionTechnician[]
  allowances  DeploymentAllowance[]
  purchases   Purchase[]
  expenses    Expense[]
  advances    AdvanceRequest[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model MissionTechnician {
  id         String   @id @default(cuid())
  missionId  String
  employeeId String
  locked     Boolean  @default(false)
  mission    Mission  @relation(fields: [missionId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@unique([missionId, employeeId])
}

model DeploymentAllowance {
  id         String   @id @default(cuid())
  missionId  String
  employeeId String
  days       Int
  rateMad    Decimal  @db.Decimal(8, 2)
  totalMad   Decimal  @db.Decimal(12, 2)
  approved   Boolean  @default(true)
  mission    Mission  @relation(fields: [missionId], references: [id])
  createdAt  DateTime @default(now())
}

model Purchase {
  id             String              @id @default(cuid())
  projectId      String
  missionId      String?
  submittedById  String
  item           String
  category       String
  amount         Decimal             @db.Decimal(12, 2)
  approvedAmount Decimal?            @db.Decimal(12, 2)
  paymentMethod  PaymentMethod
  receiptPath    String?
  notes          String?
  status         ApprovalStatus      @default(PENDING)
  project        Project             @relation(fields: [projectId], references: [id])
  mission        Mission?            @relation(fields: [missionId], references: [id])
  approvals      Approval[]
  receipts       ReceiptAttachment[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Expense {
  id             String              @id @default(cuid())
  projectId      String
  missionId      String?
  submittedById  String
  category       String
  amount         Decimal             @db.Decimal(12, 2)
  approvedAmount Decimal?            @db.Decimal(12, 2)
  adminOverride  Boolean             @default(false)
  receiptPath    String?
  notes          String?
  status         ApprovalStatus      @default(PENDING)
  project        Project             @relation(fields: [projectId], references: [id])
  mission        Mission?            @relation(fields: [missionId], references: [id])
  approvals      Approval[]
  receipts       ReceiptAttachment[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ReceiptAttachment {
  id         String    @id @default(cuid())
  filePath   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  costMad    Decimal   @default(0) @db.Decimal(12, 2)
  note       String?
  purchaseId String?
  expenseId  String?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  expense    Expense?  @relation(fields: [expenseId], references: [id])
  createdAt  DateTime  @default(now())
}

model AdvanceRequest {
  id            String         @id @default(cuid())
  projectId     String
  missionId     String?
  requestedById String
  category      String
  amount        Decimal        @db.Decimal(12, 2)
  reason        String
  status        ApprovalStatus @default(PENDING)
  overrideById  String?
  project       Project        @relation(fields: [projectId], references: [id])
  mission       Mission?       @relation(fields: [missionId], references: [id])
  approvals     Approval[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Approval {
  id             String          @id @default(cuid())
  actorId        String
  actor          User            @relation(fields: [actorId], references: [id])
  status         ApprovalStatus
  reason         String?
  approvedAmount Decimal?        @db.Decimal(12, 2)
  purchaseId     String?
  expenseId      String?
  advanceId      String?
  purchase       Purchase?       @relation(fields: [purchaseId], references: [id])
  expense        Expense?        @relation(fields: [expenseId], references: [id])
  advance        AdvanceRequest? @relation(fields: [advanceId], references: [id])
  createdAt      DateTime        @default(now())
}

model CashAccount {
  id        String         @id @default(cuid())
  name      String
  type      String
  balance   Decimal        @default(0) @db.Decimal(14, 2)
  movements CashMovement[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model CashMovement {
  id          String       @id @default(cuid())
  accountId   String
  account     CashAccount  @relation(fields: [accountId], references: [id])
  type        MovementType
  amount      Decimal      @db.Decimal(14, 2)
  description String
  projectId   String?
  supplierId  String?
  taxId       String?
  createdById String
  createdAt   DateTime     @default(now())
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  invoices  SupplierInvoice[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model SupplierInvoice {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  number     String
  amount     Decimal  @db.Decimal(14, 2)
  paidAmount Decimal  @default(0) @db.Decimal(14, 2)
  dueDate    DateTime
  filePath   String?
  createdAt  DateTime @default(now())
}

model TaxObligation {
  id        String   @id @default(cuid())
  type      TaxType
  period    String
  amountDue Decimal  @db.Decimal(14, 2)
  paid      Decimal  @default(0) @db.Decimal(14, 2)
  dueDate   DateTime
  status    String   @default("UPCOMING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id         String          @id @default(cuid())
  sku        String          @unique
  name       String
  category   String
  quantity   Int             @default(0)
  lowStockAt Int             @default(5)
  movements  StockMovement[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model StockMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])
  type      MovementType
  quantity  Int
  notes     String?
  createdAt DateTime      @default(now())
}

model Vehicle {
  id             String       @id @default(cuid())
  plate          String       @unique
  model          String
  driverId       String?      @unique
  driver         Employee?    @relation("VehicleDriver", fields: [driverId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  missions       Mission[]
  mileage        Int          @default(0)
  fuelUsage      Decimal      @default(0) @db.Decimal(10, 2)
  googleMapsLink String?
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  locationType   LocationType @default(MANUAL)
  oilChangeDue   DateTime?
  insuranceDue   DateTime?
  inspectionDue  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model LocationUpdate {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  missionId      String?
  note           String
  googleMapsLink String?
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  locationType   LocationType @default(MANUAL)
  createdAt      DateTime     @default(now())
}

model ProfitScenario {
  id                 String       @id @default(cuid())
  projectId          String
  project            Project      @relation(fields: [projectId], references: [id])
  name               String
  manualCost         Decimal      @default(0) @db.Decimal(14, 2)
  revenue            Decimal      @db.Decimal(14, 2)
  totalCost          Decimal      @db.Decimal(14, 2)
  profit             Decimal      @db.Decimal(14, 2)
  marginPercent      Decimal      @db.Decimal(8, 2)
  breakEven          Decimal      @db.Decimal(14, 2)
  recommendedPricing Decimal      @db.Decimal(14, 2)
  status             ProfitStatus
  createdById        String
  createdAt          DateTime     @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
}

model BossRoomCredential {
  id           String   @id @default("boss-room")
  passcodeHash String
  updatedById  String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model BossRoomAccessLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())
}
